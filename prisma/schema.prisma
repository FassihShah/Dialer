generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  super_admin
  admin
  user
}

enum UserStatus {
  active
  suspended
  pending
}

enum LeadStatus {
  new
  cold
  warm
  meeting_booked
  not_interested
  callback
  do_not_call
}

enum CallOutcome {
  cold
  warm
  meeting_booked
  not_interested
  callback
  no_answer
  do_not_call
}

enum NumberStatus {
  active
  inactive
}

enum DNCReason {
  DNC_Requested
  Unsubscribed
  Manually_Added
  Other
}

enum FollowUpStatus {
  pending
  completed
  cancelled
}

enum ImportStatus {
  processing
  completed
  failed
}

// ─── Models ──────────────────────────────────────────────────────────────────

model Workspace {
  id           String     @id @default(cuid())
  name         String
  slug         String     @unique
  status       UserStatus @default(active)
  createdById  String?    @map("created_by_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  users         User[]
  leads         Lead[]
  phoneNumbers  PhoneNumber[]
  voipConfigs   VoIPConfig[]
  callLogs      CallLog[]
  followUps     FollowUp[]
  dncEntries    DNCEntry[]
  importBatches ImportBatch[]

  @@map("workspaces")
}

model User {
  id                   String        @id @default(cuid())
  email                String        @unique
  name                 String
  password             String
  role                 UserRole      @default(user)
  status               UserStatus    @default(pending)
  agentPhone           String?       @map("agent_phone")
  // NOTE: super_admin users have workspaceId = null (cross-tenant)
  subscriberReference  String?       @map("subscriber_reference")
  workspaceId          String?       @map("workspace_id")
  workspace            Workspace?    @relation(fields: [workspaceId], references: [id])
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")
  createdById          String?       @map("created_by_id")

  leads                Lead[]        @relation("CreatedLeads")
  assignedLeads        Lead[]        @relation("AssignedLeads")
  callLogs             CallLog[]
  followUps            FollowUp[]
  phoneAssignment      PhoneNumberAssignment?
  importBatches        ImportBatch[]
  auditLogs            AuditLog[]

  @@map("users")
}

model Lead {
  id                 String      @id @default(cuid())
  userId             String      @map("user_id")
  user               User        @relation("CreatedLeads", fields: [userId], references: [id])
  workspaceId        String?     @map("workspace_id")
  workspace          Workspace?  @relation(fields: [workspaceId], references: [id])
  assignedToId       String?     @map("assigned_to_id")
  assignedTo         User?       @relation("AssignedLeads", fields: [assignedToId], references: [id], onDelete: SetNull)

  fullName           String      @map("full_name")
  companyName        String?     @map("company_name")
  companyWebsite     String?     @map("company_website")
  phone              String
  normalizedPhone    String?     @map("normalized_phone")
  email              String?
  normalizedEmail    String?     @map("normalized_email")
  jobTitle           String?     @map("job_title")
  industry           String?
  region             String?
  notes              String?     @db.Text
  altPhones          String?     @map("alt_phones")
  status             LeadStatus  @default(new)
  callCount          Int         @default(0) @map("call_count")
  lastCalledAt       DateTime?   @map("last_called_at")
  followUpDate       DateTime?   @map("follow_up_date")
  followUpNotes      String?     @map("follow_up_notes") @db.Text
  calledInSession    Boolean     @default(false) @map("called_in_session")
  queueOrder         Int         @default(0) @map("queue_order")
  source             String?
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")

  callLogs           CallLog[]
  followUps          FollowUp[]

  @@index([userId])
  @@index([workspaceId])
  @@index([assignedToId])
  @@index([normalizedPhone])
  @@index([normalizedEmail])
  @@map("leads")
}

// Per-workspace dedup indexes — PostgreSQL partial unique indexes defined via migration
// (workspace_id, normalizedPhone): unique where normalizedPhone IS NOT NULL
// (workspace_id, normalizedEmail): unique where normalizedEmail IS NOT NULL
// See migration 0002_workspaces.

model PhoneNumber {
  id             String      @id @default(cuid())
  phoneNumber    String      @unique @map("phone_number")
  workspaceId    String?     @map("workspace_id")
  workspace      Workspace?  @relation(fields: [workspaceId], references: [id])
  label          String?
  country        String?
  countryCode    String?     @map("country_code")
  signalwireSid  String?     @map("signalwire_sid")
  status         NumberStatus @default(active)
  notes          String?
  addedById      String?     @map("added_by_id")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  assignment     PhoneNumberAssignment?
  callLogs       CallLog[]

  @@index([workspaceId])
  @@map("phone_numbers")
}

model PhoneNumberAssignment {
  id             String      @id @default(cuid())
  userId         String      @unique @map("user_id")
  user           User        @relation(fields: [userId], references: [id])
  phoneNumberId  String      @unique @map("phone_number_id")
  phoneNumber    PhoneNumber @relation(fields: [phoneNumberId], references: [id])
  assignedById   String?     @map("assigned_by_id")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  @@index([userId])
  @@index([phoneNumberId])
  @@map("phone_number_assignments")
}

model CallLog {
  id               String       @id @default(cuid())
  userId           String       @map("user_id")
  user             User         @relation(fields: [userId], references: [id])
  workspaceId      String?      @map("workspace_id")
  workspace        Workspace?   @relation(fields: [workspaceId], references: [id])
  leadId           String?      @map("lead_id")
  lead             Lead?        @relation(fields: [leadId], references: [id])
  leadName         String?      @map("lead_name")
  leadCompany      String?      @map("lead_company")
  calledFromId     String?      @map("called_from_id")
  calledFrom       PhoneNumber? @relation(fields: [calledFromId], references: [id])
  calledFromNumber String?      @map("called_from_number")
  callSid          String?      @map("call_sid")
  dateTime         DateTime     @default(now()) @map("date_time")
  durationSeconds  Int          @default(0) @map("duration_seconds")
  outcome          CallOutcome?
  notes            String?      @db.Text
  recordingUrl     String?      @map("recording_url")
  followUpCreated  Boolean      @default(false) @map("follow_up_created")
  followUpDate     DateTime?    @map("follow_up_date")
  followUpNotes    String?      @map("follow_up_notes") @db.Text
  createdAt        DateTime     @default(now()) @map("created_at")

  @@index([userId])
  @@index([workspaceId])
  @@index([leadId])
  @@index([callSid])
  @@map("call_logs")
}

model FollowUp {
  id              String         @id @default(cuid())
  leadId          String         @map("lead_id")
  lead            Lead           @relation(fields: [leadId], references: [id])
  userId          String         @map("user_id")
  user            User           @relation(fields: [userId], references: [id])
  workspaceId     String?        @map("workspace_id")
  workspace       Workspace?     @relation(fields: [workspaceId], references: [id])
  followUpDate    DateTime       @map("follow_up_date")
  followUpTime    String?        @map("follow_up_time")
  followUpNotes   String?        @map("follow_up_notes") @db.Text
  status          FollowUpStatus @default(pending)
  reminderSent    Boolean        @default(false) @map("reminder_sent")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  @@index([userId])
  @@index([workspaceId])
  @@index([leadId])
  @@map("follow_ups")
}

model DNCEntry {
  id            String    @id @default(cuid())
  workspaceId   String?   @map("workspace_id")
  workspace     Workspace? @relation(fields: [workspaceId], references: [id])
  contactName   String?   @map("contact_name")
  email         String?
  normalizedEmail String? @map("normalized_email")
  phone         String?
  normalizedPhone String? @map("normalized_phone")
  company       String?
  reason        DNCReason @default(Manually_Added)
  addedById     String?   @map("added_by_id")
  addedByName   String?   @map("added_by_name")
  notes         String?
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([workspaceId])
  @@index([normalizedPhone])
  @@index([normalizedEmail])
  @@map("dnc_entries")
}

model VoIPConfig {
  id                         String   @id @default(cuid())
  workspaceId                String?  @map("workspace_id")
  workspace                  Workspace? @relation(fields: [workspaceId], references: [id])
  provider                   String   @default("signalwire")
  projectId                  String   @map("project_id")
  apiToken                   String   @map("api_token")
  spaceUrl                   String   @map("space_url")
  sharedSubscriberReference  String?  @map("shared_subscriber_reference")
  sharedSubscriberPassword   String?  @map("shared_subscriber_password")
  signalwireNumber           String?  @map("signalwire_number")
  dialAddress                String?  @map("dial_address")
  active                     Boolean  @default(false)
  configuredById             String?  @map("configured_by_id")
  createdAt                  DateTime @default(now()) @map("created_at")
  updatedAt                  DateTime @updatedAt @map("updated_at")

  @@index([workspaceId])
  @@map("voip_configs")
}

model ImportBatch {
  id              String       @id @default(cuid())
  userId          String       @map("user_id")
  user            User         @relation(fields: [userId], references: [id])
  workspaceId     String?      @map("workspace_id")
  workspace       Workspace?   @relation(fields: [workspaceId], references: [id])
  fileName        String?      @map("file_name")
  totalRows       Int          @default(0) @map("total_rows")
  importedRows    Int          @default(0) @map("imported_rows")
  duplicateRows   Int          @default(0) @map("duplicate_rows")
  invalidRows     Int          @default(0) @map("invalid_rows")
  status          ImportStatus @default(processing)
  errors          Json?
  createdAt       DateTime     @default(now()) @map("created_at")

  @@index([userId])
  @@map("import_batches")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?  @map("user_id")
  user       User?    @relation(fields: [userId], references: [id])
  action     String
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  details    Json?
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("audit_logs")
}
